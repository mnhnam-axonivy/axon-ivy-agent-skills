{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://json-schema.axonivy.com/process/13.2.0/process.json",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "kind": {
      "$ref": "process/ProcessKind.json"
    },
    "elements": {
      "type": "array",
      "items": {
        "$ref": "elements/ElementNode.json"
      }
    },
    "layout": {
      "$ref": "visual/VisualLayout.json"
    }
  },
  "required": [
    "id",
    "kind"
  ]
}